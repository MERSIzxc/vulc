{
  "manifest_version": 3,
  "name": "Vulcan Grade Tracker",
  "version": "1.0",
  "description": "Автоматически сохраняет оценки с Vulcan на твой сервер",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://uonetplus.vulcan.net.pl/*",
    "https://uczen.eduvulcan.pl/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://uonetplus.vulcan.net.pl/*/Uczen/Oceny*",
        "https://uczen.eduvulcan.pl/*/oceny*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
